  author   = {Wang, Eric and Kawaoka, Shinpei and Roe, Jae-Seok and Shi, Junwei and Hohmann, Anja F and Xu, Yali and Bhagwat, Anand S and Suzuki, Yutaka and Kinney, Justin B and Vakoc, Christopher R}, 
  journal  = {{eLife}}, 
  doi      = {10.7554/elife.06377}, 
  pmid     = {25919951}, 
  pmcid    = {{PMC}4409649}, 
  abstract = {Most mammalian transcription factors ({TFs}) and cofactors occupy thousands of genomic sites and modulate the expression of large gene networks to implement their biological functions. In this study, we describe an exception to this paradigm. {TRIM}33 is identified here as a lineage dependency in B cell neoplasms and is shown to perform this essential function by associating with a single cis element. {ChIP}-seq analysis of {TRIM}33 in murine B cell leukemia revealed a preferential association with two lineage-specific enhancers that harbor an exceptional density of motifs recognized by the {PU}.1 {TF}. {TRIM}33 is recruited to these elements by {PU}.1, yet acts to antagonize {PU}.1 function. One of the {PU}.1/{TRIM}33 co-occupied enhancers is upstream of the pro-apoptotic gene Bim, and deleting this enhancer renders {TRIM}33 dispensable for leukemia cell survival. These findings reveal an essential role for {TRIM}33 in preventing apoptosis in B lymphoblastic leukemia by interfering with enhancer-mediated Bim activation.}, 
  pages    = {e06377}, 
  volume   = {4}, 
  language = {English}, 
  note     = {Wrote (coauthored)}, 
  month    = {04}
}

@article{Kinney2014el, 
  year     = {2014}, 
